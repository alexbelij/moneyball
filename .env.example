# Root .env.example | Moneyball Cabinet
#
# This project uses a pnpm monorepo. Backend and frontend have
# separate env files; see apps/backend/.env.example for full details.
#
# Copy this file to .env for shared root-level configuration.

# ── Shared ───────────────────────────────────────────────────────────
NODE_ENV=development

# ── Backend (override at apps/backend/.env) ──────────────────────────
# PORT=3001
# JWT_SECRET=CHANGE-ME-32-chars-minimum
# STORAGE_BACKEND=file

# ── Frontend (Vite picks up VITE_ vars automatically) ───────────────
VITE_BACKEND_URL=http://localhost:3001
