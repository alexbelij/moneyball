# .env.example | v1.0.0 | 2026-06-12
# Copy to .env and fill in real values. All vars are optional with sane defaults
# unless marked REQUIRED.

# ── Server ───────────────────────────────────────────────────────────────
PORT=3001                                       # HTTP + WebSocket port
CORS_ORIGINS=https://your-walrus-site.wal.app   # Comma-separated allowed origins (REQUIRED for prod)

# ── Auth / JWT ───────────────────────────────────────────────────────────
JWT_SECRET=CHANGE-ME-32-chars-minimum           # REQUIRED — sign/verify JWTs
AUTH_NONCE_TTL_MS=300000                         # Nonce expiry (default 5 min)
AUTH_DOMAIN=your-walrus-site.wal.app             # Domain shown in wallet sign prompt
AUTH_URI=https://your-walrus-site.wal.app        # URI shown in wallet sign prompt

# ── Admin ────────────────────────────────────────────────────────────────
ADMIN_ALLOWLIST=0xabc123,0xdef456               # Comma-separated Sui addresses (lowercase)

# ── Storage (MemWal) ────────────────────────────────────────────────────
STORAGE_BACKEND=memwal                           # "file" for local dev, "memwal" for mainnet
MEMWAL_KEY=                                      # REQUIRED for memwal — API key from memory.walrus.xyz
MEMWAL_ACCOUNT_ID=                               # REQUIRED for memwal — account ID
MEMWAL_RELAYER=https://relayer.memory.walrus.xyz # Relayer URL (default is mainnet)
MEMWAL_NAMESPACE=moneyball                       # Namespace prefix for all stored data

# ── Match pipeline ──────────────────────────────────────────────────────
MATCH_SOURCE=manual                              # "football-data" or "manual"
FOOTBALL_DATA_TOKEN=                             # API token from football-data.org (if MATCH_SOURCE=football-data)
MATCH_POLL_SECONDS=120                           # How often to poll for match updates
PREDICTION_LEAD_HOURS=48                         # Generate predictions N hours before kickoff

# ── Sleep / evolution triggers ──────────────────────────────────────────
SLEEP_MIN_RESOLVED=3                             # Min resolved outcomes before sleep cycle
SLEEP_MIN_MINUTES=30                             # Min minutes between sleep cycles
