    "immer": "^10.1.1",
    "mitt": "^3.0.1",
    "phaser": "^3.80.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^3.2.1",
    "@playwright/test": "^1.52.0",
