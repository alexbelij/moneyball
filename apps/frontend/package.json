{
  "name": "@moneyball/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:deploy": "DEPLOY_MODE=1 tsc && DEPLOY_MODE=1 vite build",
